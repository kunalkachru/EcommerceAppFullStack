# Copy to src/.env (gitignored) — never commit real keys.
#   cp src/.env.example src/.env
#
# Used by verify:llm-live, Maestro ML demos, and optional in-app LLM paste.
# Keys are read at runtime from this file or process env (OPENAI_API_KEY, etc.).

OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Appetize / BrowserStack upload (optional — never commit real values)
APPETIZE_API_TOKEN=
APPETIZE_PUBLIC_KEY_ANDROID=
APPETIZE_PUBLIC_KEY_IOS=
BROWSERSTACK_USERNAME=
BROWSERSTACK_ACCESS_KEY=
